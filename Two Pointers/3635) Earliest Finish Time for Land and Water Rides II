class Solution {
public:

    int minFinishTime(vector<int>& start1, vector<int>& duration1, vector<int>& start2, vector<int>& duration2){
        int case1 = INT_MAX;
        for(int i = 0; i < start1.size(); i++){
            case1 = min(case1, start1[i] + duration1[i]);
        }

        int case2 = INT_MAX;
        for(int i = 0; i < start2.size(); i++){
            case2 = min(case2, max(case1, start2[i]) + duration2[i]);
        }
        return case2;
    }

    int earliestFinishTime(vector<int>& landStartTime, vector<int>& landDuration, vector<int>& waterStartTime, vector<int>& waterDuration) {
        // First Land is fixed then water.
        int result1 = minFinishTime(landStartTime, landDuration, waterStartTime, waterDuration);

        //First water is fixed then land.
        int result2 = minFinishTime(waterStartTime, waterDuration, landStartTime, landDuration); 

        return min(result1, result2); 
    }
};
