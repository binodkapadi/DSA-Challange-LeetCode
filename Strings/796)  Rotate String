class Solution {
public:
    bool rotateString(string s, string goal) {
        int n = s.length();
        int m = goal.length();
        
        if(n != m)   return false;  //if length of both string is diffrent

        for(int i = 0; i < n; i++){
            if(s == goal)  return true;

            rotate(s.begin(), s.begin() + 1, s.end());
        }
        return false;
    }
};
