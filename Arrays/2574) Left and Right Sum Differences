class Solution {
public:
    vector<int> leftRightDifference(vector<int>& nums) {
        int n = nums.size();

        int sum = accumulate(begin(nums), end(nums), 0);

        vector<int> result(n);

        int curr = 0;

        for(int i= 0; i < n; i++){
            int leftSum = curr;

            curr += nums[i];

            int rightSum = sum - curr;

            result[i] = abs(leftSum - rightSum);
        }
        return result;  
    }
};
