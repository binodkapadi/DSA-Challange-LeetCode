--------------APPROACH 1 [BRUTFORCE APPROACH] ---------------------

class Solution {
public:
    vector<int> gcdValues(vector<int>& nums, vector<long long>& queries) {

        int n = nums.size();

        vector<int> gcdPairs;

        for(int i = 0; i < n; i++){
            for (int j = i + 1; j < n; j++) {
                gcdPairs.push_back(__gcd(nums[i], nums[j]));
            }    
        }

        sort(begin(gcdPairs), end(gcdPairs));

        vector<int> ans;

        for(int i = 0; i < queries.size(); i++){
            ans.push_back(gcdPairs[queries[i]]);
        }
        return ans;
    }
};


