class Solution {
public:
    int earliestFinishTime(vector<int>& landStartTime, vector<int>& landDuration, vector<int>& waterStartTime, vector<int>& waterDuration) {
        int n = landStartTime.size();
        int m = waterStartTime.size();

        int result = INT_MAX;

        for (int i = 0; i < n; ++i) {
            for (int j = 0; j < m; ++j) {
                
                int land_cost = landStartTime[i] + landDuration[i];
                int water_cost = waterStartTime[j] + waterDuration[j];

                // Case 1: Land ride first, then water ride
                int case1 = max(land_cost, waterStartTime[j]) + waterDuration[j];

                result = min(result, case1);
                
                // Case 2: Water ride first, then land ride
                int case2 = max(water_cost, landStartTime[i]) + landDuration[i];

                result = min(result, case2);
            }
        }
        return result;    
    }
};
