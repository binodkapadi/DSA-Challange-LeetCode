class Solution {
public:
    long long countMajoritySubarrays(vector<int>& nums, int target) {
        unordered_map<int , int> map;

        int cumSum = 0;
        map[0] = 1;

        long long validLeftPoints = 0;
        long long result = 0;

        for(int i = 0 ; i < nums.size(); i++){
            if(nums[i] == target){
                validLeftPoints += map[cumSum];
                cumSum += 1;
            }else{
                cumSum -= 1;
                validLeftPoints -= map[cumSum];
            }
            map[cumSum] += 1;
            result += validLeftPoints;
        }
        return result;
    }
};
