class Solution {
public:
    int countMajoritySubarrays(vector<int>& nums, int target) {
        int n = nums.size();
        //For counting sub arrays in which target is majority element.
        int count = 0;

        for(int i = 0; i < n; i++){
            //For counting target inside the sub arrays.
            int cnt = 0;
            for(int j = i; j < n; j++){
                if(nums[j] == target){
                    cnt++;
                }
                // length of subarray length = (j-i+1)
                if(2 * cnt > (j-i+1)){
                    count++;
                }  
            } 
        }
        return count;
    }
};
