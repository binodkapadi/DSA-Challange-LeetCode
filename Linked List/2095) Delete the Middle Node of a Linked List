class Solution {
public:
    ListNode* deleteMiddle(ListNode* head) {
        ListNode* prevSlow  = NULL;
        ListNode* slow      = head;
        ListNode* fast      = head;
        
        while(fast && fast->next) {
            prevSlow = slow;
            slow     = slow->next;
            
            fast     = fast->next->next;
        }
        
        if(prevSlow == NULL) {
            return NULL;
        }
        
        prevSlow->next = slow->next;
        delete(slow);
        
        return head;
    }
};
