class Solution {
public:
    int maximumElementAfterDecrementingAndRearranging(vector<int>& arr) {
        int n = arr.size();

        sort(begin(arr), end(arr));
        
        //First element of an arr must be 1.
        arr[0] = 1;

        for(int i = 1; i < n; i++){
            if(abs(arr[i] - arr[i-1]) > 1){
                arr[i] = min(arr[i],arr[i-1] + 1);
            }
        }
        return arr[n-1];//after sorting the last element must be the max element
    }
};
