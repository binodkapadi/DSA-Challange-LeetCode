class Solution {
public:
    int reverseNum(int num){
        long long rev = 0;
        while(num > 0){
            rev = (rev * 10) + (num % 10);
            num /= 10;
        }
        return (int)rev;
    }
    
    int mirrorDistance(int n) {
        int md = abs(n - reverseNum(n)); //Calculating the mirroR distance 
        return md; // Returning this distance
    }
};
